        {
            "name": "Events",
            "description": "",
            "item": [
                {
                    "name": "List on-chain events.",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/events",
                            "query": [
                                {
                                    "key": "event_type",
                                    "value": "",
                                    "description": "Filter by event type. One of: `RaffleCreated`, `TicketPurchased`, `WinnerPicked`, `RaffleExpired`, `UnderfilledPrizeReturned`, `PlatformFeeCollected`, `FeeChangeProposed`.",
                                    "disabled": true
                                },
                                {
                                    "key": "since_block",
                                    "value": "39000000",
                                    "description": "Only return events at or after this block number.",
                                    "disabled": false
                                },
                                {
                                    "key": "tx_hash",
                                    "value": "0xabc123",
                                    "description": "Filter by transaction hash.",
                                    "disabled": false
                                },
                                {
                                    "key": "per_page",
                                    "value": "20",
                                    "description": "Number of results per page (default: 20, max: 100).",
                                    "disabled": false
                                }
                            ],
                            "raw": "{{baseUrl}}\/api\/events?event_type=&since_block=39000000&tx_hash=0xabc123&per_page=20"
                        },
                        "method": "GET",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": null,
                        "description": "Returns a paginated list of all successfully processed on-chain events,\nordered by blockchain ordering (`block_number` DESC, `log_index` DESC).",
                        "auth": {
                            "type": "noauth"
                        }
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"current_page\": 1,\n  \"data\": [\n    {\n      \"id\": 42,\n      \"event_type\": \"TicketPurchased\",\n      \"source\": \"webhook\",\n      \"block_number\": 39000100,\n      \"log_index\": 3,\n      \"tx_hash\": \"0xabc123\",\n      \"event_data\": {\"raffle_id\": 7, \"buyer\": \"0xdef456\", \"ticket_count\": 2},\n      \"created_at\": \"2026-04-11 09:00:00\"\n    }\n  ],\n  \"first_page_url\": \"http:\/\/localhost\/api\/events?page=1\",\n  \"from\": 1,\n  \"last_page\": 5,\n  \"last_page_url\": \"http:\/\/localhost\/api\/events?page=5\",\n  \"next_page_url\": \"http:\/\/localhost\/api\/events?page=2\",\n  \"path\": \"http:\/\/localhost\/api\/events\",\n  \"per_page\": 20,\n  \"prev_page_url\": null,\n  \"to\": 20,\n  \"total\": 97\n}",
                            "name": ""
                        }
                    ]
                },
                {
                    "name": "Stream on-chain events (SSE).",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/events\/stream",
                            "query": [
                                {
                                    "key": "last_block",
                                    "value": "39000100",
                                    "description": "Resume cursor \u2014 block number of the last received event.",
                                    "disabled": false
                                },
                                {
                                    "key": "last_log_index",
                                    "value": "3",
                                    "description": "Resume cursor \u2014 log index of the last received event.",
                                    "disabled": false
                                },
                                {
                                    "key": "event_type",
                                    "value": "TicketPurchased",
                                    "description": "Filter by event type. One of: `RaffleCreated`, `TicketPurchased`, `WinnerPicked`, `RaffleExpired`, `UnderfilledPrizeReturned`, `PlatformFeeCollected`, `FeeChangeProposed`.",
                                    "disabled": false
                                }
                            ],
                            "raw": "{{baseUrl}}\/api\/events\/stream?last_block=39000100&last_log_index=3&event_type=TicketPurchased"
                        },
                        "method": "GET",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": null,
                        "description": "Opens a persistent **Server-Sent Events** connection that pushes every\nraffle event in blockchain order (`block_number` ASC \u2192 `log_index` ASC).\n\nOn first connection (no cursor) the server replays the latest 50 events\nand then polls every 3 seconds for new ones.\nUse the `Last-Event-ID` header (format: `{block_number}:{log_index}`) or\nthe `last_block` \/ `last_log_index` query params to resume from a cursor.\n\nEach pushed message has the SSE event name **`event_log`**:\n```\nid: 39000100:3\nevent: event_log\ndata: {\"id\":42,\"event_type\":\"TicketPurchased\",\"source\":\"webhook\", ...}\n```\n\nA `\": heartbeat\"` comment is sent when there are no new events to keep\nthe connection alive.",
                        "auth": {
                            "type": "noauth"
                        }
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"id\": \"39000100:3\",\n  \"event\": \"event_log\",\n  \"data\": {\n    \"id\": 42,\n    \"event_type\": \"TicketPurchased\",\n    \"source\": \"webhook\",\n    \"block_number\": 39000100,\n    \"log_index\": 3,\n    \"tx_hash\": \"0xabc123\",\n    \"event_data\": {\"raffle_id\": 7, \"buyer\": \"0xdef456\", \"ticket_count\": 2},\n    \"created_at\": \"2026-04-11 09:00:00\"\n  }\n}",
                            "name": "SSE stream (text\/event-stream)"
                        }
                    ]
                }
            ]
        },
